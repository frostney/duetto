# Build artefacts (per the native-nostalgia-stack build-system contract,
# everything output by the build lands under build/ and is not committed).
build/

# LWPT toolkit state — the install workspace and the ephemeral install
# lock. The committed state under .lwpt/modules/ is NOT gitignored
# (zero-install, mirroring lwpt's ADR-0002).
.lwpt/tmp/
.lwpt/install.lock

# FPC artefacts. These should never appear with -FE build, but defensive
# in case a contributor runs fpc by hand without the output-dir flag.
*.o
*.ppu
*.rsj
*.compiled

# Autobahn testsuite output (reports are generated, never committed).
tests/autobahn/reports/

# OS noise.
.DS_Store
Thumbs.db

# Autobahn reports from the native macOS merge job (and local runs of
# its recipe) — generated, like tests/autobahn/reports/.
reports-macos/
